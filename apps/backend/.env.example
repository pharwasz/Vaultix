# Database Configuration
DATABASE_PATH=./data/vaultix.db

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m

# Environment
NODE_ENV=development

# Server Configuration
PORT=3000

# Stellar Configuration
STELLAR_NETWORK=testnet
WALLET_SECRET="your-stellar-wallet-secret"
STELLAR_TIMEOUT=60000
STELLAR_MAX_RETRIES=3
STELLAR_RETRY_DELAY=1000

# Email (SMTP) Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
EMAIL_FROM=no-reply@vaultix.io

# App Version Gating
APP_MIN_SUPPORTED_VERSION=1.0.0
APP_LATEST_VERSION=1.0.0
APP_UPDATE_URL=https://apps.apple.com/app/vaultix/id0000000000
